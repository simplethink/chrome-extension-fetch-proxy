{
  "name": "chrome-extension-fetch-proxy",
  "version": "1.0.0",
  "description": "A Chrome extension fetch proxy library for handling cross-origin requests through background scripts",
  "main": "dist/chrome-extension-fetch-proxy.js",
  "module": "dist/chrome-extension-fetch-proxy.esm.js",
  "browser": "dist/chrome-extension-fetch-proxy.umd.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "chrome-extension",
    "fetch",
    "proxy",
    "cross-origin",
    "background-script"
  ],
  "author": "Qihao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplethink/chrome-extension-fetch-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/simplethink/chrome-extension-fetch-proxy/issues"
  },
  "homepage": "https://github.com/simplethink/chrome-extension-fetch-proxy#readme",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.29.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.0.0"
  }
}